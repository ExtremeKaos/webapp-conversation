# APP ID
NEXT_PUBLIC_APP_ID=
# APP API key
NEXT_PUBLIC_APP_KEY=
# API url prefix
NEXT_PUBLIC_API_URL=
# Basic Auth (opcional — si se dejan vacíos, la app queda abierta)
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# --- Auth por JWT del host (identidad usuario/empresa) ---
# Secreto compartido para verificar el JWT que inyecta el host (HS256, PoC).
# Para pasar a RS256/JWKS: vaciar JWT_VERIFY_SECRET y definir JWT_JWKS_URL.
JWT_VERIFY_SECRET=
# JWT_JWKS_URL=
# Emisor y audiencia esperados en el JWT del host
JWT_ISSUER=gextor-host
JWT_AUDIENCE=gextor-chatbot
# Secreto para firmar el token de sesión propio (distinto de JWT_VERIFY_SECRET)
SESSION_SECRET=
# Orígenes permitidos para el postMessage del host (separados por comas).
# El propio origen del chatbot siempre está permitido (demo.html).
NEXT_PUBLIC_ALLOWED_HOST_ORIGINS=
